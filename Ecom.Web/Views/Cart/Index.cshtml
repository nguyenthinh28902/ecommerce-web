@using Ecom.Web.Shared.Models.Cart
@model CartViewModel

@{
    ViewData["Title"] = "giỏ hàng của bạn";
}

<div class="bg-white min-h-screen">
    <div class="max-w-[1000px] mx-auto px-4 py-16">
        @if (Model.Items == null || !Model.Items.Any())
        {
            @* Case: Giỏ hàng trống *@
            <div class="text-center py-20">
                <h1 class="text-4xl font-bold text-[#1d1d1f] mb-4">giỏ hàng của bạn đang trống.</h1>
                <p class="text-gray-500 mb-8">Giao hàng miễn phí và trả hàng miễn phí cho mọi đơn hàng.</p>
                <a asp-controller="Home" asp-action="Index" class="bg-[#0071e3] text-white px-8 py-3 rounded-full font-medium hover:bg-[#0077ed] transition">
                    Tiếp tục mua sắm
                </a>
            </div>
        }
        else
        {
            @* Case: Có hàng trong túi *@
            <div class="mb-12">
                <h1 class="text-4xl font-bold text-[#1d1d1f] mb-2">giỏ hàng của bạn.</h1>
                <p class="text-[17px]">Tổng cộng: <span class="font-semibold">@Model.GrandTotal.ToString("N0") @("₫")</span>. Miễn phí giao hàng.</p>
            </div>

            <div class="grid grid-cols-1 lg:grid-cols-12 gap-12">
                @* Danh sách sản phẩm *@
                <div class="lg:col-span-8 space-y-8">
                    @foreach (var item in Model.Items)
                    {
                        <div class="flex gap-6 pb-8 border-b border-gray-200" id="item-@item.ProductId">
                            <div class="w-32 h-32 flex-shrink-0 bg-[#f5f5f7] rounded-xl overflow-hidden">
                                <img src="@(item.MainImage ?? "/images/no-image.png")" class="w-full h-full object-contain p-2" />
                            </div>

                            <div class="flex-grow flex flex-col justify-between">
                                <div class="flex justify-between items-start">
                                    <div>
                                        <h3 class="text-[19px] font-semibold text-[#1d1d1f]">@item.ProductName</h3>
                                        <p class="text-[14px] text-gray-500">@item.VariantName</p>
                                    </div>
                                    <div class="text-right">
                                        <p class="text-[19px] font-semibold">@item.UnitPrice.ToString("N0") ₫</p>
                                    </div>
                                </div>

                                <div class="flex justify-between items-end mt-4">
                                    <div class="flex items-center border border-gray-300 rounded-lg overflow-hidden">
                                        <button onclick="updateQty(@item.ProductId, -1)" class="px-3 py-1 hover:bg-gray-100">-</button>
                                        <span class="px-4 py-1 border-x border-gray-300 text-sm font-medium" id="qty-@item.ProductId">@item.Quantity</span>
                                        <button onclick="updateQty(@item.ProductId, 1)" class="px-3 py-1 hover:bg-gray-100">+</button>
                                    </div>
                                    <button onclick="removeItem(@item.ProductId)" class="text-[#0066cc] text-[14px] hover:underline">Xóa</button>
                                </div>
                            </div>
                        </div>
                    }

                    <div class="flex justify-between pt-4">
                        <a asp-controller="Home" asp-action="Index" class="text-[#0066cc] hover:underline flex items-center gap-1">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M15 19l-7-7 7-7"></path></svg>
                            Tiếp tục mua sắm
                        </a>
                        <form asp-controller="Cart" asp-action="ClearCart" method="post">
                            <button type="submit" class="text-red-500 text-sm hover:underline">Xóa toàn bộ giỏ hàng</button>
                        </form>
                    </div>
                </div>

                @* Sidebar Tóm tắt đơn hàng *@
                <div class="lg:col-span-4 space-y-6">
                    <div class="sticky top-24 space-y-6">
                        <div class="space-y-4">
                            <div class="flex justify-between text-[14px]">
                                <span class="text-gray-500">Tạm tính</span>
                                <span>@Model.GrandTotal.ToString("N0") ₫</span>
                            </div>
                            <div class="flex justify-between text-[14px]">
                                <span class="text-gray-500">Vận chuyển</span>
                                <span>@Model.ShippingText</span>
                            </div>
                            <div class="flex justify-between text-[14px]">
                                <span class="text-gray-500">Thuế (VAT 10%)</span>
                                <span>Thanh toán chung với sản phẩm</span>
                            </div>
                            <hr class="border-gray-200" />
                            <div class="flex justify-between text-[19px] font-bold">
                                <span>Tổng cộng</span>
                                <span>@(Model.GrandTotal.ToString("N0")) ₫</span>
                            </div>
                        </div>

                        <a href="@Url.Action("Index", "Order")"
                           class="block text-center w-full bg-[#0071e3] text-white py-4 rounded-xl font-semibold text-[17px] hover:bg-[#0077ed] transition shadow-sm">
                            Thanh toán
                        </a>

                        <p class="text-[12px] text-gray-400 text-center">Chúng tôi chấp nhận thẻ tín dụng, chuyển khoản và Apple Pay.</p>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        async function updateQty(productId, change) {
            // Gọi AJAX tới API Order Service (qua Proxy của Web app)
            // Cập nhật giao diện mà không load lại trang
            console.log("Cập nhật sản phẩm " + productId + " thêm: " + change);
            location.reload(); // Tạm thời reload để cập nhật giá
        }

        async function removeItem(productId) {
            if(confirm("Xóa sản phẩm này khỏi giỏ hàng?")) {
                // Gọi API DELETE .../api/gio-hang/xoa-item
                location.reload();
            }
        }
    </script>
}