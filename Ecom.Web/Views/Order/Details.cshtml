@using Ecom.Web.Shared.Models.Order
@model OrderDetailViewModel
@{
    ViewData["Title"] = "Chi tiết đơn hàng " + Model.OrderCode;
}

<div class="max-w-[800px] mx-auto px-4 py-12">
    <a asp-action="OrderHistory" asp-controller="Order" class="text-[#0071e3] hover:underline mb-4 inline-block">< Quay lại lịch sử</a>
    <h1 class="text-[32px] font-semibold mb-2 tracking-tight">Chi tiết đơn hàng</h1>
    <p class="text-gray-500 mb-8">Mã đơn: @Model.OrderCode | Đặt ngày @Model.CreatedAt?.ToString("dd/MM/yyyy HH:mm")</p>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-12">
        <div class="bg-white rounded-2xl p-6 shadow-sm border border-gray-100">
            <h4 class="font-semibold mb-4 border-b pb-2">Thông tin giao hàng</h4>
            <p class="font-medium">@Model.FullName</p>
            <p class="text-gray-600 text-sm">@Model.PhoneNumber</p>
            <p class="text-gray-600 text-sm mt-2 italic">@Model.ShippingAddress</p>
        </div>

        <div class="bg-white rounded-2xl p-6 shadow-sm border border-gray-100">
            <h4 class="font-semibold mb-4 border-b pb-2">Thanh toán</h4>
            @if (Model.TransactionInfo != null)
            {
                <p class="text-sm">Phương thức: <b>@Model.TransactionInfo.PaymentMethodName</b></p>
                <p class="text-sm">Trạng thái: <span class="text-green-600 font-medium">@Model.TransactionInfo.StatusName</span></p>
                <p class="text-[11px] text-gray-400 mt-2">Mã GD: @Model.TransactionInfo.ExternalTransactionId</p>
            }
            else
            {
                <p class="text-gray-400 italic">Đang chờ thanh toán hoặc COD</p>
            }
        </div>
    </div>

    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden mb-8">
        <table class="w-full">
            <thead class="bg-[#f5f5f7] text-[13px] text-gray-500">
                <tr>
                    <th class="py-3 px-6 text-left font-medium">Sản phẩm</th>
                    <th class="py-3 px-6 text-center font-medium">SL</th>
                    <th class="py-3 px-6 text-right font-medium">Thành tiền</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
                @foreach (var item in Model.OrderItems)
                {
                    <tr>
                        <td class="py-4 px-6 flex items-center gap-4">
                            <img src="@item.ProductMainImage" class="w-16 h-16 rounded-xl object-cover" />
                            <div>
                                <p class="font-semibold text-[#1d1d1f]">@item.ProductName</p>
                                <p class="text-[12px] text-gray-400">SKU: @item.Sku</p>
                            </div>
                        </td>
                        <td class="py-4 px-6 text-center text-gray-600">@item.Quantity</td>
                        <td class="py-4 px-6 text-right font-medium">@item.TotalLineAmount.ToString("N0") @Model.Currency</td>
                    </tr>
                }
            </tbody>
            <tfoot>
                <tr class="bg-[#f5f5f7]/50">
                    <td colspan="2" class="py-4 px-6 text-right font-semibold">Tổng cộng</td>
                    <td class="py-4 px-6 text-right text-xl font-bold text-[#1d1d1f]">@Model.TotalAmount.ToString("N0") @Model.Currency</td>
                </tr>
            </tfoot>
        </table>
    </div>
</div>