@using Ecom.Web.Shared.Models.Order
@model List<OrderHistoryViewModel>
@{
    ViewData["Title"] = "Lịch sử đơn hàng";
}

<div class="max-w-[1000px] mx-auto px-4 py-12">
    <h1 class="text-[32px] font-semibold mb-8 tracking-tight">Đơn hàng của bạn</h1>

    @if (!Model.Any())
    {
        <div class="bg-white rounded-2xl p-12 text-center shadow-sm border border-gray-100">
            <p class="text-gray-500">Bạn chưa có đơn hàng nào.</p>
            <a href="/" class="text-[#0071e3] hover:underline mt-4 inline-block">Tiếp tục mua sắm</a>
        </div>
    }
    else
    {
        <div class="space-y-6">
            @foreach (var order in Model)
            {
                <div class="bg-white rounded-2xl p-6 shadow-sm border border-gray-100 hover:shadow-md transition">
                    <div class="flex justify-between items-start mb-4">
                        <div>
                            <p class="text-[13px] text-gray-500 uppercase tracking-wider">Mã đơn hàng</p>
                            <h3 class="text-lg font-semibold text-[#1d1d1f]">@order.OrderCode</h3>
                            <p class="text-sm text-gray-400">Ngày đặt: @order.CreatedAt?.ToString("dd/MM/yyyy")</p>
                        </div>
                        <div class="text-right">
                            <span class="px-3 py-1 rounded-full text-[12px] font-medium @(order.StatusName == "Completed" ? "bg-green-100 text-green-700" : "bg-orange-100 text-orange-700")">
                                @order.StatusName
                            </span>
                            <p class="mt-2 text-xl font-semibold text-[#1d1d1f]">@order.TotalAmount.ToString("N0") @order.Currency</p>
                        </div>
                    </div>

                    <div class="flex gap-4 overflow-x-auto pb-4">
                        @foreach (var item in order.OrderItems)
                        {
                            <div class="flex items-center gap-3 min-w-[200px] bg-[#f5f5f7] rounded-xl p-3">
                                <img src="@item.ProductMainImage" class="w-12 h-12 rounded-lg object-cover bg-white" />
                                <div class="overflow-hidden">
                                    <p class="text-sm font-medium truncate">@item.ProductName</p>
                                    <p class="text-xs text-gray-500">SL: @item.Quantity</p>
                                </div>
                            </div>
                        }
                    </div>

                    <div class="mt-4 pt-4 border-t border-gray-50 flex justify-end">
                        <a asp-action="Details" asp-route-code="@order.OrderCode" class="text-[14px] font-medium text-[#0071e3] hover:underline">Xem chi tiết đơn hàng ></a>
                    </div>
                </div>
            }
        </div>
    }
</div>