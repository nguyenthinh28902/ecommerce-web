@using Ecom.Web.Shared.Models.Checkout
@model CheckoutViewModel

@{
    ViewData["Title"] = "Xác nhận đơn hàng";
}

<div class="bg-[#f5f5f7] min-h-screen py-12">
    <div class="max-w-[800px] mx-auto px-4">

        @using (Html.BeginForm("PlaceOrder", "Order", FormMethod.Post))
        {
            @Html.AntiForgeryToken()

            <div class="bg-white rounded-3xl shadow-sm border border-gray-200 overflow-hidden mb-8">
                <div class="p-8">
                    <h1 class="text-[32px] font-bold text-[#1d1d1f] mb-6 text-center">Kiểm tra lại đơn hàng.</h1>

                    <div class="space-y-6">
                        @for (int i = 0; i < Model.Items.Count; i++)
                        {
                            var item = Model.Items[i];
                            <div class="flex items-center gap-6 py-4 border-b border-gray-50 last:border-0">
                                @* Chỉ comment dòng quan trọng: Render Item kèm Hidden fields để không mất data khi POST *@
                                @Html.HiddenFor(m => m.Items[i].ProductId)
                                @Html.HiddenFor(m => m.Items[i].VariantId)
                                @Html.HiddenFor(m => m.Items[i].Quantity)
                                @Html.HiddenFor(m => m.Items[i].UnitPrice)

                                <div class="w-20 h-20 bg-[#f5f5f7] rounded-xl flex-shrink-0 flex items-center justify-center">
                                    <img src="@(item.ImageUrl ?? "/images/default-pro.jpg")" class="w-16 h-16 object-contain" />
                                </div>

                                <div class="flex-grow">
                                    <h3 class="text-[17px] font-semibold text-[#1d1d1f]">@item.ProductName</h3>
                                    <p class="text-[14px] text-gray-500">Phân loại: @item.VariantName</p>
                                    <p class="text-[14px] text-gray-500">Số lượng: @item.Quantity</p>
                                    @if (!item.IsAvailable)
                                    {
                                        <span class="text-red-500 text-[12px] font-medium italic">* Sản phẩm này hiện không thể đặt hàng</span>
                                    }
                                </div>
                                <div class="text-right">
                                    <span class="text-[17px] font-medium">@((item.UnitPrice * item.Quantity).ToString("N0"))₫</span>
                                </div>
                            </div>
                        }
                    </div>

                    <div class="mt-8 bg-[#f5f5f7] rounded-2xl p-6 space-y-3">
                        <div class="flex justify-between text-gray-600">
                            <span>Tạm tính</span>
                            <span>@Model.SubTotal.ToString("N0")₫</span>
                        </div>
                        <div class="flex justify-between text-gray-600">
                            <span>Phí vận chuyển</span>
                            <span>@Model.ShippingFee.ToString("N0")₫</span>
                        </div>
                        <div class="flex justify-between text-[22px] font-bold text-[#1d1d1f] border-t border-gray-200 pt-3 mt-2">
                            <span>Tổng thanh toán</span>
                            <span class="text-[#0071e3]">@Model.TotalAmount.ToString("N0")₫</span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="bg-white rounded-3xl shadow-sm border border-gray-200 p-8 mb-8">
                <h2 class="text-2xl font-semibold mb-6">Địa chỉ nhận hàng</h2>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <label class="block text-[13px] font-bold text-gray-400 uppercase tracking-wider mb-2">Địa chỉ giao hàng</label>
                        @Html.TextAreaFor(m => m.FullName, new {
                        @class = "w-full bg-[#f5f5f7] border-none rounded-xl px-4 py-3 text-[17px] focus:ring-2 focus:ring-[#0071e3] transition-all outline-none",
                                        rows = "1",
                                        placeholder = "Tên khách hàng khi nhận hàng" 
                                                                                                                                                                                                })
                </div>
                    <div>
                        <label class="block text-[13px] font-bold text-gray-400 uppercase tracking-wider mb-2">Số điện thoại</label>
                        @Html.TextBoxFor(m => m.PhoneNumber, new {
                        @class = "w-full bg-[#f5f5f7] border-none rounded-xl px-4 py-3 text-[17px] focus:ring-2 focus:ring-[#0071e3] transition-all outline-none",
                                        placeholder = "Số điện thoại liên lạc" 
                                                                                                })
                </div>
                <div>
                    <label class="block text-[13px] font-bold text-gray-400 uppercase tracking-wider mb-2">Địa chỉ giao hàng</label>
                    @Html.TextAreaFor(m => m.ShippingAddress, new {
                                        @class = "w-full bg-[#f5f5f7] border-none rounded-xl px-4 py-3 text-[17px] focus:ring-2 focus:ring-[#0071e3] transition-all outline-none",
                                        rows = "1",
                                        placeholder = "Địa chỉ nhận hàng chi tiết" 
                                                                                                })
                </div>
               
            </div>
        </div>
        <div class="bg-white rounded-3xl shadow-sm border border-gray-200 p-8 mb-8">
            <h2 class="text-2xl font-semibold mb-6">Phương thức thanh toán</h2>

            
                <div class="mt-8 bg-white rounded-3xl p-8 border border-gray-200">
                    
                    <div class="space-y-4">
                        @foreach (var method in Model.PaymentMethods)
                        {
                            <label class="flex items-center p-4 border rounded-xl cursor-pointer hover:bg-gray-50 transition">
                                @Html.RadioButtonFor(m => m.SelectedPaymentMethodCode, method.Code, new { @class = "mr-3" })
                                <span class="font-medium">@method.Name</span>
                            </label>
                        }
                    </div>
                </div>
            </div>
       

        <div class="text-center pb-20">
            <button type="submit"
                    @(Model.IsAllItemsAvailable ? "" : "disabled")
                    class="w-full md:w-[400px] @(Model.IsAllItemsAvailable ? "bg-[#0071e3] hover:bg-[#0077ed]" : "bg-gray-300 cursor-not-allowed") text-white py-4 rounded-full font-semibold text-[17px] transition shadow-lg inline-block">
                @(Model.IsAllItemsAvailable ? "Hoàn tất đặt hàng" : "Vui lòng kiểm tra lại giỏ hàng")
            </button>
            <p class="mt-4 text-gray-400 text-[13px]">Bạn có thể hủy đơn hàng bất cứ lúc nào trước khi vận chuyển.</p>
        </div>
                }
    </div>
</div>