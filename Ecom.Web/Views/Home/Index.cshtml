@using Ecom.Web.Shared.Models.Product;
@model HomeProductDisplayViewModel;
@{
    ViewData["Title"] = "Trang chủ";
}

<section class="bg-white pt-16 pb-8 text-center">
<div class="max-w-4xl mx-auto px-6">
    <h2 class="text-xs font-bold text-orange-600 mb-2 uppercase tracking-widest">Mới</h2>
    <h1 class="text-6xl font-bold tracking-tight mb-4">MacBook Air M4</h1>
    <p class="text-2xl font-light text-gray-600 mb-8">Siêu mỏng. Siêu mạnh. Siêu AI.</p>
    <div class="flex justify-center gap-6 mb-12">
        <button class="bg-[#0071e3] text-white px-8 py-2.5 rounded-full font-medium hover:bg-[#0077ed]">Mua</button>
        <button class="text-[#0071e3] font-medium hover:underline">Tìm hiểu thêm ></button>
    </div>

    <div class="w-full aspect-video bg-gradient-to-tr from-gray-100 to-gray-200 rounded-t-3xl shadow-2xl border-x border-t border-gray-300 mx-auto">
        <div class="flex h-full items-center justify-center text-gray-400 italic">4K Cinematic Product Shot</div>
    </div>
</div>
</section>

@if (Model.NewArrivals.Any())
{
    var heroProduct = Model.NewArrivals.First();
    <section class="bg-white pt-16 pb-8 text-center border-b border-gray-100">
        <div class="max-w-4xl mx-auto px-6">
            <h2 class="text-xs font-bold text-orange-600 mb-2 uppercase tracking-widest">Mới</h2>
            <h1 class="text-6xl font-bold tracking-tight mb-4">@heroProduct.Name</h1>
            <p class="text-2xl font-light text-gray-600 mb-8">@heroProduct.BrandName - Trải nghiệm sức mạnh đột phá.</p>
            <div class="flex justify-center gap-6 mb-12">
                <a href="/product/@heroProduct.NameAscii" class="bg-[#0071e3] text-white px-8 py-2.5 rounded-full font-medium hover:bg-[#0077ed]">Mua ngay</a>
                <span class="text-2xl font-semibold text-gray-900">@heroProduct.Price.ToString("N0") @heroProduct.CurrencyUnit</span>
            </div>

            <div class="w-full aspect-video rounded-t-3xl shadow-2xl border-x border-t border-gray-200 mx-auto overflow-hidden">
                <img src="@(heroProduct.MainImage ?? "/images/default-pro.jpg")" alt="@heroProduct.Name" class="w-full h-full object-cover" />
            </div>
        </div>
    </section>
}

<section class="max-w-[1200px] mx-auto p-6 mt-12">
    <h2 class="text-3xl font-semibold mb-8">Sản phẩm mới về</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        @foreach (var item in Model.NewArrivals.Skip(1)) // Bỏ qua sản phẩm Hero đầu tiên
        {
            @await Html.PartialAsync("_ProductCard", item)
        }
    </div>
</section>

<section class="bg-[#f5f5f7] py-16 mt-12">
    <div class="max-w-[1200px] mx-auto px-6">
        <h2 class="text-3xl font-semibold mb-8 text-center">Ưu đãi cực sốc</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
            @foreach (var item in Model.BestDeals)
            {
                // Gọi Partial View và truyền model của từng item vào
                <partial name="_ProductCard" model="item" />
            }
        </div>
    </div>
</section>

@section Scripts {
    <script>
        console.log("E-commerce Home Loaded with Real Data!");
    </script>
}